rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. User Profiles
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // 2. Monitoring Activities (Reports)
    match /activity/{studentId}/daily_reports/{reportDate} {
      // Students can only create or append to their OWN reports
      allow create, update: if request.auth != null && request.auth.uid == studentId;
      
      // DELETION: Forbidden for students. 
      // Only the 3-day rolling logic (system) or Admin can delete.
      allow delete: if request.auth != null && (
        request.auth.uid == studentId || 
        get(/databases/$(database)/documents/users/$(studentId)).data.createdBy == request.auth.uid
      );

      // READ: Student reads own, Admin reads their students
      allow read: if request.auth != null && (
        request.auth.uid == studentId || 
        get(/databases/$(database)/documents/users/$(studentId)).data.createdBy == request.auth.uid
      );
    }

    // 3. Tamper Logs
    match /tamper_logs/{logId} {
      // Students can only create logs (automated alerts)
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      // ONLY Admin can read/delete tamper logs
      allow read, delete: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // 4. Device Attestation
    match /devices/{studentId} {
      allow read, write: if request.auth != null && request.auth.uid == studentId;
    }

    // 5. Notifications Queue
    match /admin_notifications_queue/{alertId} {
      allow create: if request.auth != null;
      allow read, delete: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
